      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ================================================================ -->
        <!--  TITLE & OVERVIEW                                                 -->
        <!-- ================================================================ -->
        <mxCell id="title" value="ViMACSA — Encode-Once, Aspect-Loop Architecture&#xa;&#xa;Multimodal ACSA Model (MultimodalACSAModel)&#xa;src/aspect_model.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;align=center;fontStyle=bold;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="820" height="80" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  INPUT STAGE                                                      -->
        <!-- ================================================================ -->
        <mxCell id="lbl_input" value="INPUT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="box_input" value="+--------------------------------------------------------------+
| Input                                                         |
|  comment ─────────────────────────────────────────────────────┤
|  images [B, M, 3, 256, 256] ─────────────────────────────────┤
|  roi_data per image ──────────────────────────────────────────┤
+--------------------------------------------------------------+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;fontFamily=Courier New;spacing=0;spacingTop=0;spacingBottom=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="820" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrow: Input → Encoding -->
        <mxCell id="arrow_input_enc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="280" as="sourcePoint"/>
            <mxPoint x="470" y="300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_input_enc" value="output:
- H_txt [B, L_txt, 2560]
- H_patch [B, M, P', 2560]
- H_img_sum [B, M, 2560]
- H_roi [B, M, K', 2560]" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="280" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  ENCODING STAGE (all frozen)                                     -->
        <!-- ================================================================ -->
        <mxCell id="lbl_encoding" value="ENCODING (FROZEN)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="295" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="box_encoding" value="+--------------------------------------------------------------+
| ENCODING (all frozen)                                         |
|  comment ──► llm.embed_tokens() ─────► H_txt [B, L_txt, 2560] |
|                                                               |
| images ───► SigLIPEncoder ──► patch_feats [B, M, P, 1152]     |
|               │              img_summaries [B, M, 1152]       |
|               │                                                   |
|               └─► encode_roi(pixel_values, roi_data)            |
|                                       └─► roi_seq [B, M, K, 1152]
+--------------------------------------------------------------+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;fontFamily=Courier New;spacing=0;spacingTop=0;spacingBottom=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="325" width="820" height="140" as="geometry"/>
        </mxCell>

        <!-- Arrow: Encoding → Projection -->
        <mxCell id="arrow_enc_proj" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="465" as="sourcePoint"/>
            <mxPoint x="470" y="485" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_enc_proj" value="output:
- H_txt [B, L_txt, 2560]
- H_patch [B, M, P', 2560]
- H_img_sum [B, M, 2560]
- H_roi [B, M, K', 2560]" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="465" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  PROJECTION STAGE (trainable)                                    -->
        <!-- ================================================================ -->
        <mxCell id="lbl_proj" value="PROJECTION (TRAINABLE)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="box_proj" value="+--------------------------------------------------------------+
| PROJECTION (trainable)                                        |
|  patch_feats ──► MLPProjector ──► H_patch [B, M, P', 2560]    |
|  roi_seq ───────► RoIProjector ──► H_roi [B, M, K', 2560]    |
|  img_summaries ─► Linear(1152→2560) ──► H_img_sum [B, M, 2560]
+--------------------------------------------------------------+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;fontFamily=Courier New;spacing=0;spacingTop=0;spacingBottom=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="820" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrow: Projection → Aspect Loop -->
        <mxCell id="arrow_proj_loop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="620" as="sourcePoint"/>
            <mxPoint x="470" y="645" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_proj_loop" value="output:
- H_txt, H_patch, H_img_sum, H_roi
- img_mask [B, M]
- roi_mask [B, M*K']" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="620" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  ASPECT LOOP — main processing box                               -->
        <!-- ================================================================ -->
        <mxCell id="lbl_loop" value="ASPECT LOOP (shared weights, 6 iterations: a = 0..5)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="820" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="box_loop" value="+--------------------------------------------------------------+
| ASPECT LOOP (shared weights, 6 iterations: a = 0..5)          |
|                                                               |
|  For each aspect a:                                           |
|                                                               |
|  aspect_queries[a] ────────────────────────────► ASP_a [B, 2560]
|                                                               |
|  TextRetriever (cross-attention, 8 heads):                   |
|  H_txt ─┬─────────────────────────────► TXT_EVI_a [B, 2560]  |
|         │  attention_mask [B, L_txt]                           |
|                                                               |
|  ImageRetriever (cross-attention, 4 heads):                   |
|  H_img_sum ─┬────────────────────────► IMG_EVI_a [B, 2560]   |
|              │  img_mask [B, M]                               |
|                                                               |
|  RoiRetriever (cross-attention, 4 heads):                     |
|  H_roi ──────┬────────────────────────► ROI_EVI_a [B, 2560] |
|              │  roi_mask [B, M*K']                             |
|                                                               |
|  GatedFusion:                                                 |
|  [TXT_EVI] ─┤                                                  |
|  [IMG_EVI] ──┼─► GatedFusion ──────► FUSE_a [B, 2560]        |
|  [ROI_EVI] ─┘                                                  |
|                                                               |
|  5-token sequence:                                             |
|  [ASP_a | TXT_EVI_a | IMG_EVI_a | ROI_EVI_a | FUSE_a]         |
|                                                               |
|  Shared LLM decoder:                                          |
|  [ASP]──┐                                                     |
|  [TXT]──┤                                                     |
|  [IMG]──┼─► Qwen3-4B + LoRA ──► last_hidden ──► Classification │
|  [ROI]──┤       (r=64)       [B, 5, 2560]      Head ──►     |
|  [FUSE]─┘                                    logits_a [B, 4] |
|                                                               |
|  logits stacked:                                              |
|  └────────────────────────────────► logits [B, 6, 4]        |
+--------------------------------------------------------------+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;fontFamily=Courier New;spacing=0;spacingTop=0;spacingBottom=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="670" width="820" height="350" as="geometry"/>
        </mxCell>

        <!-- Arrow: Aspect Loop → Output -->
        <mxCell id="arrow_loop_out" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="1020" as="sourcePoint"/>
            <mxPoint x="470" y="1045" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_loop_out" value="output:
- logits [B, 6, 4]
- targets [B, 6]
- loss (CrossEntropy)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="1020" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  OUTPUT / LOSS STAGE                                              -->
        <!-- ================================================================ -->
        <mxCell id="lbl_output" value="OUTPUT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="1040" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="box_output" value="+--------------------------------------------------------------+
| CrossEntropyLoss                                              |
|  loss = CE(logits [B*6, 4], targets [B*6])                   |
|  classes: 0=Irrelative, 1=Negative, 2=Neutral, 3=Positive   |
+--------------------------------------------------------------+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;fontFamily=Courier New;spacing=0;spacingTop=0;spacingBottom=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="1070" width="820" height="80" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  COMPONENT DETAILS SIDEBAR                                       -->
        <!-- ================================================================ -->
        <mxCell id="lbl_details" value="Component Details" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=bold;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="920" y="170" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="comp_details" value="ENCODING (FROZEN)
━━━━━━━━━━━━━━━━━━━━━━
SigLIP2-Large (google/siglip2-so400m-patch16-256)
LLM embed_tokens (Qwen3-4B-Instruct)

PROJECTION (TRAINABLE)
━━━━━━━━━━━━━━━━━━━━━━
MLPProjector: Linear(1152→2560), GELU, Linear(2560→2560)
RoIProjector: Linear(1152→2560), GELU, Linear(2560→2560)
img_sum_projector: Linear(1152→2560)

ASPECT LOOP (SHARED, TRAINABLE)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AspectQuery: Embedding(6, 2560) — Gaussian init
TextRetriever: Cross-Attention, 8 heads
ImageRetriever: Cross-Attention, 4 heads
RoiRetriever: Cross-Attention, 4 heads
GatedFusion: 3 sigmoid gates + LayerNorm
build_aspect_sequence(): [B,5,2560] seq
Qwen3-4B + LoRA r=64 (frozen backbone + LoRA)
ClassificationHead: LayerNorm + FC + GELU + FC→4

6 Aspects: Facilities, Public_area,
Location, Food, Room, Service

Classes: 0=Irrelative, 1=Negative,
2=Neutral, 3=Positive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontFamily=Courier New;align=left;spacing=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="340" height="500" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!--  LEGEND                                                           -->
        <!-- ================================================================ -->
        <mxCell id="legend" value="Legend
━━━━━━━━━━━━━━━━━━━━━━━
  Yellow box = frozen module
  Red box    = trainable module
  Purple box = aspect-loop / shared weights
  Orange box = output / loss
━━━━━━━━━━━━━━━━━━━━━━━
Color border coding:
  Blue border = input
  Yellow border = frozen
  Red border = trainable
  Purple border = aspect loop
  Orange border = output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontFamily=Courier New;align=left;" vertex="1" parent="1">
          <mxGeometry x="920" y="720" width="340" height="160" as="geometry"/>
        </mxCell>

